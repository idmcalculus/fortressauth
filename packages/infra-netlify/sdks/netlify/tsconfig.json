{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "config/index.ts",
        "config/vars.ts",
        "deployKey.ts",
        "dnsRecord.ts",
        "dnsZone.ts",
        "environmentVariable.ts",
        "getDnsZone.ts",
        "getManagedWafRules.ts",
        "getSite.ts",
        "getSites.ts",
        "getTeam.ts",
        "index.ts",
        "logDrain.ts",
        "provider.ts",
        "siteBuildSettings.ts",
        "siteCollaborationSettings.ts",
        "siteDomainSettings.ts",
        "siteFirewallTrafficRules.ts",
        "siteMetricsSettings.ts",
        "teamFirewallTrafficRules.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "utilities.ts",
        "wafPolicy.ts"
    ]
}
