# FortressAuth Angular Example - Environment Variables
# Copy this file to .env and update the values as needed.
#
# Angular reads the API URL from the ANGULAR_API_URL environment variable when provided.
# If omitted, it falls back to src/environments/environment.ts in development and
# src/environments/environment.prod.ts in production builds.
ANGULAR_API_URL=http://localhost:5001

# Optional deployment base path for production builds.
# Use / when the app is deployed at the domain root.
# Use /angular-demo/ when it is mounted under the landing domain.
DEMO_BASE_PATH=/

# CORS Configuration Note:
# The FortressAuth server must have this origin in its CORS_ORIGINS configuration.
# For local development, the server allows localhost:5173 and localhost:5174 by default.
# Angular typically runs on localhost:4200, so you may need to add it to the server's CORS_ORIGINS.
#
# Example server configuration:
# CORS_ORIGINS=http://localhost:4200,http://localhost:5173,http://localhost:3000
#
# The Angular SDK automatically includes credentials: 'include' in all fetch requests,
# which is required for cookie-based authentication to work across origins.
